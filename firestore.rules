rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() { return request.auth != null; }
    function isOwner(uid) { return isSignedIn() && request.auth.uid == uid; }
    function role() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }
    function isAdmin() { return isSignedIn() && role() == "admin"; }

    match /users/{uid} {
      allow read:  if isOwner(uid) || isAdmin();
      allow write: if isOwner(uid);
    }

    match /patients/{uid} {
      allow read:  if isOwner(uid) || isAdmin();
      allow write: if isOwner(uid) || isAdmin();
    }

    match /hospitals/{uid} {
      allow read:  if isSignedIn();
      allow create: if isOwner(uid) || isAdmin();
      allow update: if isOwner(uid) || isAdmin();
      allow delete: if isAdmin();
    }

    match /doctors/{uid} {
      allow read:  if isSignedIn();
      allow write: if isOwner(uid) || isAdmin();
    }

    match /mri_slots/{slotId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.hospitalId == request.auth.uid;
      allow update, delete: if isSignedIn() && (resource.data.hospitalId == request.auth.uid || isAdmin());
    }

    match /doctor_slots/{slotId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.doctorId == request.auth.uid;
      allow update: if isSignedIn() && (
        resource.data.doctorId == request.auth.uid ||
        (resource.data.available == true && request.resource.data.status == 'reserved') ||
        isAdmin()
      );
      allow delete: if isSignedIn() && (resource.data.doctorId == request.auth.uid || isAdmin());
    }

    match /care_journeys/{journeyId} {
      allow read: if isSignedIn() && (resource.data.patientId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && request.resource.data.patientId == request.auth.uid;
      allow update, delete: if isSignedIn() && (resource.data.patientId == request.auth.uid || isAdmin());
    }

    match /patient_documents/{docId} {
      allow read: if isSignedIn() && (resource.data.patientId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && request.resource.data.patientId == request.auth.uid;
      allow update, delete: if isSignedIn() && (resource.data.patientId == request.auth.uid || isAdmin());
    }

    match /bookings/{bookingId} {
      allow read: if isSignedIn() && (
        resource.data.patientId == request.auth.uid ||
        resource.data.doctorId == request.auth.uid ||
        isAdmin()
      );
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (
        resource.data.patientId == request.auth.uid ||
        resource.data.doctorId == request.auth.uid ||
        isAdmin()
      );
      allow delete: if isAdmin();
    }

    match /admin_audit_log/{logId} {
      allow read:  if isAdmin();
      allow write: if isAdmin();
    }

    match /notifications/{notificationId} {
      allow read:  if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow write: if isAdmin();
    }
  }
}

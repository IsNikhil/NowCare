## Firestore Collections

### `/users/{uid}`
```ts
{ uid: string, email: string, role: 'patient'|'doctor'|'hospital'|'admin', createdAt: Timestamp }
```

### `/patients/{uid}`
```ts
{ uid, displayName?, age, gender, lat?, lng?, allergies?, medications?, emergencyContact? }
```
`lat/lng` set by browser Geolocation API from ProviderResults page — saved with `setDoc(..., { merge: true })`.

### `/hospitals/{uid}`
```ts
{
  uid, name, email, status: 'pending'|'approved'|'denied',
  lat, lng, phone, address,
  er_status?: 'low'|'moderate'|'high'|'closed',  // set manually by hospital staff
  er_updated?: Timestamp,
  cms_data: { facility_id, facility_name, address, city, state, zip_code,
              phone_number, hospital_type, hospital_ownership, emergency_services, overall_rating },
  cms_benchmarks: { avgERWaitMinutes: number|null, imagingEfficiencyScore: number|null },
  services: string[],
  createdAt, approvedAt?
}
```

### `/doctors/{uid}`
```ts
{
  uid, email, displayName, name, npi,
  npi_data: { npi, name, credential, specialty, active },
  verified: boolean,
  badge: 'npi_verified'|'hospital_verified',
  specialty: string,         // snake_case ID from SPECIALTIES (e.g. 'internal_medicine')
  credentials, bio, languages?,
  acceptedInsurance?: string[],  // IDs from INSURANCE_CARRIERS (e.g. 'united_healthcare')
  lat?, lng?, telehealth?,
  avgRating?, totalReviews?,
  affiliatedHospitalId?,
  createdAt
}
```

### `/mri_slots/{slotId}`
```ts
{ hospitalId, hospitalName, datetime: Timestamp, type: 'MRI'|'CT'|'X-Ray'|'Ultrasound', available: boolean }
```

### `/doctor_slots/{slotId}`
```ts
{ doctorId, doctorName, specialty, telehealth, lat, lng, datetime: Timestamp,
  available: boolean, status: 'open'|'reserved'|'blocked', durationMinutes: number }
```
Booking: sets `available → false`, `status → 'reserved'`, adds `patientId` and `bookedAt`.

### `/care_journeys/{journeyId}`
```ts
{
  patientId, symptoms,
  triage_result: { care_category, urgency, recommended_specialty?, scan_type?, short_reasoning, red_flags[], what_to_expect },
  provider_type?, selected_provider_id?, appointment_datetime?,
  pre_visit_summary?,
  createdAt
}
```

### `/patient_documents/{docId}`
```ts
{
  patientId, filename, storagePath, contentType, fileSize, uploadedAt,
  category: 'lab_result'|'prescription'|'scan_report'|'discharge_summary'|'other',
  analysisStatus: 'pending'|'complete'|'failed',
  analysis?: DocumentAnalysis  // full Gemini output
}
```

### `/bookings/{bookingId}`, `/admin_audit_log/{logId}`, `/notifications/{notificationId}`
See `src/types/index.ts` for full shapes.


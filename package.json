    "lint:emdash": "node -e \"const fs=require('fs');const path=require('path');function walk(d){for(const f of fs.readdirSync(d)){const p=path.join(d,f);if(fs.statSync(p).isDirectory()){if(!['node_modules','dist','.git'].includes(f))walk(p);}else if(/\\.(ts|tsx|js|jsx|md|html|css)$/.test(f)){const c=fs.readFileSync(p,'utf8');if(c.includes(String.fromCharCode(8212))){console.error('em dash found in',p);process.exit(1);}}}}walk('.');console.log('no em dashes found');\""
